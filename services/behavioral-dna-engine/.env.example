# Runtime environment: local | staging | production
SAQR_ENV=local

# Postgres (system of record + append-only audit trail)
SAQR_DB_DSN=postgresql+asyncpg://saqr:saqr@localhost:5432/saqr_behavioral_dna

# Redis (hot cache of current profile, not source of truth)
SAQR_REDIS_URL=redis://localhost:6379/0
SAQR_REDIS_ENABLED=true

# Kafka (structured DNA output published for downstream agents)
SAQR_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SAQR_KAFKA_OUTPUT_TOPIC=saqr.behavioral-dna.profile-updates
SAQR_KAFKA_ENABLED=true

# Minimum transaction count for full confidence in a behavioral baseline
SAQR_MIN_HISTORY_FOR_FULL_CONFIDENCE=30

# API
SAQR_API_HOST=0.0.0.0
SAQR_API_PORT=8001

# Path to the historical transactions CSV used by /profiles/backfill
SAQR_TRANSACTIONS_CSV_PATH=/data/transactions.csv
